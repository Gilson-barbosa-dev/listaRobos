<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Planos - Clube Quant</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="/output.css" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => { lucide.createIcons(); });
  </script>
  <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/img/favicon.png">
  <meta name="theme-color" content="#000000">
</head>
<body class="bg-gradient-to-br from-black via-gray-900 to-black text-white min-h-screen font-sans">

  <!-- Sidebar -->
  <%- include("partials/sidebar", { page: "planos" }) %>

  <!-- Conteúdo -->
  <main class="ml-64 p-6 flex-1">
    <div class="max-w-7xl mx-auto">

      <!-- Título -->
      <h1 class="text-2xl font-bold mb-10 flex items-center gap-2">
        <i data-lucide="credit-card" class="w-6 h-6 text-yellow-400"></i>
        <span>Gerenciamento de Planos</span>
      </h1>

      <% 
        const planoAtivo = usuario.ativo && usuario.plano && usuario.status !== 'inativo';
        const temPlano = usuario.plano && usuario.plano.trim() !== "";
      %>

      <!-- 🔸 Caso não tenha plano ativo -->
      <% if (!planoAtivo) { %>
        <div class="bg-gray-800 rounded-xl shadow-md p-6 mb-12 border border-red-600/50 relative">
          <span class="absolute top-4 right-4 bg-red-600/90 text-white text-xs font-bold px-3 py-1 rounded-full shadow">
            Nenhum Plano Ativo
          </span>
          <h2 class="text-xl font-semibold text-red-400 mb-2">Você não possui um plano ativo</h2>
          <p class="text-gray-300">
            Para continuar utilizando o Clube Quant, selecione um dos planos abaixo e realize a assinatura.
          </p>
        </div>
      <% } else { 
        const detalhesPlano = {
          starter: { preco: "R$ 97/mês", limite: "Até 4 EAs ativos simultaneamente" },
          plus: { preco: "R$ 197/mês", limite: "Até 8 EAs ativos simultaneamente" },
          premium: { preco: "R$ 297/mês", limite: "EAs ilimitados" },
          diamond: { preco: "Consulte", limite: "EAs ilimitados + suporte VIP" }
        }[usuario.plano.toLowerCase()] || { preco: "N/D", limite: "N/D" };
      %>
        <div class="bg-gray-800 rounded-xl shadow-md p-6 mb-12 border border-quant-purple/30 relative">
          <h2 class="text-xl font-semibold text-quant-purple">Seu Plano Atual</h2>
          <p class="mt-2 text-gray-300">
            Você está no plano <strong><%= usuario.plano.toLowerCase() %></strong>, válido até 
            <span class="text-quant-green font-semibold">
              <%= usuario.proxima_cobranca ? new Date(usuario.proxima_cobranca).toLocaleDateString("pt-BR") : "N/D" %>
            </span>.
          </p>
          <p class="mt-2 text-gray-300">
            <span class="font-semibold text-white">Preço:</span> <%= detalhesPlano.preco %><br>
            <span class="font-semibold text-white">Limite:</span> <%= detalhesPlano.limite %>
          </p>
          <div class="mt-4 flex justify-end">
            <a href="https://ajuda.zouti.com.br/pt-br/articles/9740970-como-solicitar-o-cancelamento-da-minha-assinatura"
              target="_blank"
              rel="noopener noreferrer"
              class="px-4 py-2 rounded-lg bg-red-600 hover:bg-red-500 transition font-semibold inline-block text-center">
              Cancelar Plano
            </a>
          </div>
        </div>
      <% } %>

      <!-- Planos disponíveis -->
      <h2 class="text-lg font-bold mb-6 px-1">Planos Disponíveis</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 px-1">
        <% 
          let planos = [
            { nome: "Starter", preco: "R$ 97/mês", desc: "Ideal para começar", limite: "4 EAs ativos", link: "https://pay.zouti.com.br/checkout?poi=prod_offer_rw4arkjywwtvst66qb6f35" },
            { nome: "Plus", preco: "R$ 197/mês", desc: "Mais recursos e flexibilidade", limite: "8 EAs ativos", link: "https://pay.zouti.com.br/checkout?poi=prod_offer_u86x1k92h6v8gu8nenhc5k" },
            { nome: "Premium", preco: "R$ 297/mês", desc: "Para traders avançados", limite: "EAs ilimitados", link: "https://pay.zouti.com.br/checkout?poi=prod_offer_ad7lhtpltf4l7lecmuiccx" },
            { nome: "Diamond", preco: "Consulte", desc: "Plano exclusivo para profissionais", limite: "EAs ilimitados + VIP", link: "http://wa.me/5511966073938" }
          ];

          // 🔹 Quando o plano estiver inativo, remove o Diamond
          if (!planoAtivo) {
            planos = planos.filter(p => p.nome.toLowerCase() !== "diamond");
          }

          const ordemPlanos = ["starter", "plus", "premium", "diamond"];
          const indiceAtual = ordemPlanos.indexOf((usuario.plano || "").toLowerCase());

          planos.forEach(plano => {
            const indicePlano = ordemPlanos.indexOf(plano.nome.toLowerCase());
            let acao = "Assinar";

            // 🔸 Ocultar o plano atual quando ativo
            if (planoAtivo && plano.nome.toLowerCase() === (usuario.plano || "").toLowerCase()) {
              return;
            }

            if (planoAtivo) {
              if (plano.nome.toLowerCase() === "diamond") acao = "Consultar";
              else if (indicePlano > indiceAtual) acao = "Upgrade";
              else if (indicePlano < indiceAtual) acao = "Downgrade";
            }
        %>
        <div class="flex flex-col justify-between bg-gray-900 border border-gray-700 rounded-xl p-6 shadow-md">
          <div>
            <h3 class="text-lg font-semibold text-white"><%= plano.nome %></h3>
            <p class="text-gray-400 mt-1"><%= plano.desc %></p>
            <p class="text-xl font-bold text-quant-green mt-4"><%= plano.preco %></p>
            <ul class="mt-4 space-y-2 text-left">
              <li class="flex items-center gap-2 text-gray-300">
                <i data-lucide="check-circle" class="w-4 h-4 text-green-400"></i>
                <span><%= plano.limite %></span>
              </li>
              <li class="flex items-center gap-2 text-gray-300">
                <i data-lucide="check-circle" class="w-4 h-4 text-green-400"></i>
                <span>Acesso completo às estratégias</span>
              </li>
              <li class="flex items-center gap-2 text-gray-300">
                <i data-lucide="check-circle" class="w-4 h-4 text-green-400"></i>
                <span>Suporte dedicado</span>
              </li>
              <li class="flex items-center gap-2 text-gray-300">
                <i data-lucide="check-circle" class="w-4 h-4 text-green-400"></i>
                <span>Comunidade ativa</span>
              </li>
              <li class="flex items-center gap-2 text-gray-300">
                <i data-lucide="check-circle" class="w-4 h-4 text-green-400"></i>
                <span>Gerenciamento de mesa</span>
              </li>
            </ul>
          </div>

          <div class="flex justify-end mt-6">
            <% if (acao === "Consultar") { %>
              <a href="<%= plano.link %>" target="_blank"
                class="flex items-center gap-2 px-3 py-1.5 rounded-md bg-gray-800 hover:bg-gray-700 text-sm text-purple-400 font-medium transition">
                <i data-lucide="message-square" class="w-4 h-4"></i> Consultar
              </a>
            <% } else { %>
              <a href="<%= plano.link %>" target="_blank"
                class="flex items-center gap-2 px-3 py-1.5 rounded-md bg-blue-600 hover:bg-blue-500 text-sm text-white font-semibold transition">
                <i data-lucide="credit-card" class="w-4 h-4"></i> <%= acao %>
              </a>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- 📖 Informações sobre limites -->
      <div class="mt-12 bg-gray-900/50 border border-gray-700 rounded-xl p-6 max-w-4xl mx-auto">
        <h3 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
          <i data-lucide="info" class="w-5 h-5 text-blue-400"></i>
          Como funciona o limite de EAs?
        </h3>
        <div class="space-y-3 text-gray-300 text-sm">
          <p class="flex items-start gap-2">
            <i data-lucide="check" class="w-4 h-4 text-green-400 mt-0.5 flex-shrink-0"></i>
            <span><strong>Downloads ilimitados:</strong> Você pode baixar quantos algoritmos quiser, sem restrições.</span>
          </p>
          <p class="flex items-start gap-2">
            <i data-lucide="check" class="w-4 h-4 text-green-400 mt-0.5 flex-shrink-0"></i>
            <span><strong>Favoritar sem limite:</strong> Adicione todos os algoritmos que desejar aos seus favoritos.</span>
          </p>
          <p class="flex items-start gap-2">
            <i data-lucide="alert-circle" class="w-4 h-4 text-yellow-400 mt-0.5 flex-shrink-0"></i>
            <span><strong>Limite de execução:</strong> O limite do plano se aplica apenas aos EAs <em>rodando simultaneamente</em> no MetaTrader. Exemplo: no plano Starter (4 EAs), você pode ter 4 robôs operando ao mesmo tempo.</span>
          </p>
          <p class="flex items-start gap-2">
            <i data-lucide="settings" class="w-4 h-4 text-cyan-400 mt-0.5 flex-shrink-0"></i>
            <span><strong>Gerenciamento de Mesa:</strong> Os robôs de gerenciamento de mesa <strong>não contam</strong> no limite. Você pode usar quantos quiser, independente do plano.</span>
          </p>
          <p class="flex items-start gap-2">
            <i data-lucide="rotate-ccw" class="w-4 h-4 text-purple-400 mt-0.5 flex-shrink-0"></i>
            <span>Para trocar um EA, basta fechar o que está rodando no MetaTrader e ativar outro. Você pode alternar livremente entre os algoritmos baixados.</span>
          </p>
        </div>
      </div>

    </div>
  </main>
</body>
</html>
